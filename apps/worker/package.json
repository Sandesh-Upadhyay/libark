{
  "name": "worker",
  "version": "1.0.0",
  "description": "LIBARK Worker Service",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "NODE_OPTIONS='--conditions=development' tsx watch src/index.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.812.0",
    "@libark/core-shared": "workspace:*",
    "@libark/core-server": "workspace:*",
    "@libark/db": "workspace:*",
    "@libark/media": "workspace:*",
    "@libark/queues": "workspace:*",
    "@libark/redis-client": "workspace:*",
    "@types/node-cron": "^3.0.11",
    "bullmq": "^5.52.3",
    "form-data": "^4.0.3",
    "ioredis": "^5.6.1",
    "node-cron": "^4.2.1",
    "sharp": "^0.33.3"
  },
  "devDependencies": {
    "@types/form-data": "^2.5.2",
    "vitest": "^3.2.4"
  },
  "ts-node": {
    "esm": true,
    "experimentalSpecifierResolution": "node",
    "compilerOptions": {
      "module": "ESNext",
      "moduleResolution": "bundler"
    }
  }
}
