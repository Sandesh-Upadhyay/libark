{
  "name": "@libark/s3-gateway",
  "version": "1.0.0",
  "description": "LIBARK S3 Gateway - Universal S3 API Proxy with Encryption",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "s3",
    "gateway",
    "proxy",
    "fastify",
    "encryption",
    "cloudflare-r2",
    "aws-s3"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.709.0",
    "@aws-sdk/lib-storage": "^3.709.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.3",
    "@libark/core-shared": "workspace:*",
    "@libark/core-server": "workspace:*",
    "@libark/redis-client": "workspace:*",
    "@libark/upload-session": "workspace:*",
    "fastify": "^5.4.0",
    "pino-pretty": "^13.0.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  }
}
