{
  "name": "frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.11.0",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 3000",
    "build": "tsc && vite build",
    "start": "vite preview --host 0.0.0.0 --port 3000",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:pretty": "vitest run --reporter=default --reporter=verbose",
    "test:watch:verbose": "vitest --reporter=verbose",
    "test:ui": "vitest --ui",
    "test:posts": "vitest run src/__tests__/integration/*post*.integration.test.tsx",
    "test:posts:cov": "vitest run --coverage --include src/features/posts/**",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:auth": "playwright test e2e/auth/",
    "lint": "eslint src/components src/pages --config ../../eslint.config.js",
    "lint:atomic": "eslint src/components --config ../../eslint.config.js",
    "lint:layout": "eslint src/pages --config ../../eslint.config.js",
    "lint:all": "eslint src/components src/pages --config ../../eslint.config.js",
    "lint:constants": "eslint src/components src/features --config ../../eslint.config.js --no-eslintrc",
    "lint:responsibility": "eslint src/components src/types src/features --config ../../eslint.config.js",
    "lint:types": "eslint src/types --config ../../eslint.config.js",
    "fix:layout": "tsx ../../scripts/fix-layout-warnings.ts"
  },
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@chatscope/chat-ui-kit-react": "^2.1.1",
    "@chatscope/chat-ui-kit-styles": "^1.4.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@hookform/resolvers": "^3.3.0",
    "@libark/core-client": "workspace:*",
    "@libark/core-shared": "workspace:*",
    "@libark/db": "workspace:*",
    "@libark/graphql-client": "workspace:*",
    "@radix-ui/react-alert-dialog": "^1.1.14",
    "@radix-ui/react-avatar": "^1.1.10",
    "@radix-ui/react-dialog": "^1.1.14",
    "@radix-ui/react-dropdown-menu": "^2.1.11",
    "@radix-ui/react-label": "^2.1.4",
    "@radix-ui/react-popover": "^1.1.14",
    "@radix-ui/react-progress": "^1.1.7",
    "@radix-ui/react-radio-group": "^1.3.4",
    "@radix-ui/react-scroll-area": "^1.2.9",
    "@radix-ui/react-select": "^2.2.4",
    "@radix-ui/react-separator": "^1.1.7",
    "@radix-ui/react-slot": "^1.2.0",
    "@radix-ui/react-switch": "^1.2.2",
    "@radix-ui/react-tabs": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.7",
    "@tanstack/react-table": "^8.21.3",
    "@types/qrcode": "^1.5.5",
    "@types/recharts": "^2.0.1",
    "@web3icons/react": "^4.0.17",
    "apollo3-cache-persist": "^0.15.0",
    "autoprefixer": "^10.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "cryptocurrency-icons": "^0.18.1",
    "date-fns": "^4.1.0",
    "date-fns-tz": "^3.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "framer-motion": "^12.23.0",
    "graphql": "^16.11.0",
    "i18next": "^24.0.5",
    "i18next-browser-languagedetector": "^8.0.2",
    "lucide-react": "^0.501.0",
    "next-themes": "^0.4.6",
    "postcss": "^8.4.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-hook-form": "^7.48.0",
    "react-i18next": "^15.1.2",
    "react-image-crop": "^11.0.7",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^6.28.0",
    "recharts": "^3.0.2",
    "sonner": "^2.0.6",
    "tailwind-merge": "^3.2.0",
    "tailwindcss": "^3.3.0",
    "tailwindcss-animate": "^1.0.7",
    "web-vitals": "^5.0.3",
    "zod": "^3.25.76",
    "zustand": "^5.0.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.10.2",
    "@types/qrcode.react": "^3.0.0",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@typescript-eslint/eslint-plugin": "^8.36.0",
    "@typescript-eslint/parser": "^8.36.0",
    "@vitejs/plugin-react": "^4.5.2",
    "@vitest/ui": "^3.2.4",
    "buffer": "^6.0.3",
    "crypto-browserify": "^3.12.1",
    "eslint": "^9.30.1",
    "eslint-plugin-unused-imports": "^4.1.4",
    "glob": "^10.3.10",
    "jest": "^30.0.4",
    "jest-environment-jsdom": "^30.0.4",
    "jsdom": "^26.1.0",
    "msw": "^2.10.4",
    "rollup-plugin-visualizer": "^5.12.0",
    "ts-jest": "^29.4.0",
    "tsx": "^4.20.3",
    "vite": "^6.0.7",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^3.2.4"
  }
}
