# Frontend local environment example (Vite)
# copy to apps/frontend/.env.local when needed

VITE_LOG_LEVEL=WARN
VITE_LOG_CATEGORIES=INIT,MEDIA,SYSTEM
VITE_LOG_THROTTLE_MS=5000
VITE_LOG_ENABLE_STRICT_MODE_DETECTION=true
VITE_PERFORMANCE_MONITOR_ENABLED=true
VITE_PERFORMANCE_MEMORY_THRESHOLD=100
VITE_PERFORMANCE_CLS_THRESHOLD=0.1
