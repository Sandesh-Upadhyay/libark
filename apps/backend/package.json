{
  "name": "@libark/backend",
  "version": "1.0.0",
  "description": "LIBARK Fastify + GraphQL Backend",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "NODE_OPTIONS='--conditions=development' tsx watch src/index.ts",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "pnpm run test:quick",
    "test:quick": "NODE_OPTIONS=\"--max-old-space-size=${TEST_MAX_OLD_SPACE_SIZE:-4096}\" vitest run --reporter=verbose --maxWorkers=1 --exclude \"src/services/__tests__/**\" --exclude \"src/**/*.integration.test.ts\" --exclude \"src/**/SessionManager.test.ts\" --exclude \"src/**/P2PTradeService.test.ts\" --exclude \"src/**/large-data.test.ts\" --exclude \"src/**/performance-*.test.ts\" --exclude \"src/**/security-*.test.ts\" --exclude \"src/**/*.security.test.ts\"",
    "test:integration": "for f in $(find src -name \"*.integration.test.ts\" | sort); do NODE_OPTIONS=\"--max-old-space-size=${TEST_MAX_OLD_SPACE_SIZE:-4096}\" vitest run --reporter=verbose --maxWorkers=1 \"$f\" || exit 1; done",
    "test:social": "NODE_OPTIONS=\"--max-old-space-size=${TEST_MAX_OLD_SPACE_SIZE:-4096}\" vitest run --reporter=verbose --maxWorkers=1 src/resolvers/__tests__/follow.integration.test.ts",
    "test:devtools": "NODE_ENV=development NODE_OPTIONS=\"--max-old-space-size=${TEST_MAX_OLD_SPACE_SIZE:-4096}\" vitest run --reporter=verbose --maxWorkers=1 src/resolvers/__tests__/cache.integration.test.ts",
    "test:performance": "for f in $(find src \\( -name \"large-data.test.ts\" -o -name \"performance-*.test.ts\" \\) | sort); do RUN_PERF=1 NODE_OPTIONS=\"--max-old-space-size=${TEST_MAX_OLD_SPACE_SIZE:-4096}\" vitest run --reporter=dot --silent=true --maxWorkers=1 \"$f\" || exit 1; done",
    "test:performance:ci": "PERF_SCALE=0.25 pnpm run test:performance",
    "test:security": "for f in $(find src \\( -name \"security-*.test.ts\" -o -name \"*.security.test.ts\" \\) | sort); do NODE_OPTIONS=\"--max-old-space-size=${TEST_MAX_OLD_SPACE_SIZE:-4096}\" vitest run --reporter=dot --silent=true --maxWorkers=1 \"$f\" || exit 1; done",
    "test:auth:session": "NODE_OPTIONS=\"--max-old-space-size=${TEST_AUTH_SESSION_MAX_OLD_SPACE_SIZE:-12288}\" vitest run --reporter=verbose --maxWorkers=1 src/auth/__tests__/SessionManager.test.ts",
    "test:p2p-service": "NODE_OPTIONS=\"--max-old-space-size=${TEST_P2P_SERVICE_MAX_OLD_SPACE_SIZE:-8192}\" vitest run --reporter=verbose --maxWorkers=1 src/services/__tests__/P2PTradeService.test.ts",
    "test:services": "NODE_OPTIONS=\"--max-old-space-size=${TEST_SERVICES_MAX_OLD_SPACE_SIZE:-8192}\" vitest run --reporter=verbose --maxWorkers=1 src/services/__tests__",
    "test:full": "pnpm run test:quick && pnpm run test:integration && pnpm run test:performance && pnpm run test:security",
    "test:watch": "vitest",
    "test:auth": "NODE_OPTIONS=\"--max-old-space-size=${TEST_MAX_OLD_SPACE_SIZE:-4096}\" vitest run --reporter=verbose --maxWorkers=1 src/auth/__tests__/ src/resolvers/__tests__/auth.integration.test.ts",
    "test:auth-report": "tsx src/auth/__tests__/run-auth-tests.ts",
    "test:coverage": "NODE_OPTIONS=\"--max-old-space-size=${TEST_MAX_OLD_SPACE_SIZE:-4096}\" vitest run --coverage --maxWorkers=1"
  },
  "keywords": [
    "fastify",
    "graphql",
    "apollo-server"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@apollo/cache-control-types": "^1.0.3",
    "@apollo/server": "^4.12.2",
    "@apollo/server-plugin-response-cache": "^4.1.4",
    "@apollo/utils.keyvaluecache": "^4.0.0",
    "@fastify/cookie": "^10.0.1",
    "@fastify/cors": "^10.1.0",
    "@fastify/helmet": "^12.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/static": "^8.2.0",
    "@graphiql/toolkit": "^0.11.3",
    "@graphql-tools/schema": "^10.0.6",
    "@libark/cache": "workspace:*",
    "@libark/core-server": "workspace:*",
    "@libark/core-shared": "workspace:*",
    "@libark/db": "workspace:*",
    "@libark/graphql": "workspace:*",
    "@libark/media": "workspace:*",
    "@libark/nowpayments-api": "workspace:*",
    "@libark/queues": "workspace:*",
    "@libark/redis-client": "workspace:*",
    "@libark/upload-session": "workspace:*",
    "@prisma/client": "^7.2.0",
    "@types/graphql-upload": "^17.0.0",
    "bcrypt": "^5.1.1",
    "dataloader": "^2.2.3",
    "fastify": "^5.4.0",
    "fastify-plugin": "^5.0.1",
    "graphiql": "^5.0.0",
    "graphql": "^16.11.0",
    "graphql-scalars": "^1.23.0",
    "graphql-upload": "^17.0.0",
    "graphql-ws": "^6.0.5",
    "ioredis": "^5.6.1",
    "jsonwebtoken": "^9.0.2",
    "lru-cache": "^11.1.0",
    "mercurius": "^16.1.0",
    "pino": "^8.21.0",
    "pino-pretty": "^13.0.0",
    "quick-lru": "^7.0.1",
    "uuid": "^11.0.3",
    "ws": "^8.18.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@faker-js/faker": "^9.9.0",
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typescript": "^4.1.0",
    "@graphql-codegen/typescript-operations": "^4.3.0",
    "@graphql-codegen/typescript-resolvers": "^4.3.0",
    "@types/bcrypt": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/uuid": "^10.0.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^3.2.4",
    "tsx": "^4.20.3",
    "vitest": "^3.2.4"
  }
}
