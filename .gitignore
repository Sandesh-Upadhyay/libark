# 依存関係
node_modules/
.pnp/
.pnp.js

# SSL証明書と秘密鍵（セキュリティ）
*.key
*.pem
cloudflare-origin.key
cloudflare-origin.crt

# ビルド出力
dist/
build/
.next/
out/

# TypeScriptビルド成果物（srcディレクトリ内に誤って生成されることを防ぐ）
packages/*/src/**/*.d.ts
packages/*/src/**/*.js
packages/*/src/**/*.js.map
packages/*/src/**/*.d.ts.map
apps/*/src/**/*.d.ts
apps/*/src/**/*.js
apps/*/src/**/*.js.map
apps/*/src/**/*.d.ts.map
*.tsbuildinfo

# Environment variables
.env
.env.*
!.env.template
!.env.example
!apps/frontend/.env.example
.env.local
.env.development.local
.env.production.local
apps/frontend/.env.local

# ログ
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# エディタ設定
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# テスト
coverage/

# キャッシュ
.eslintcache
.cache/
.parcel-cache/
