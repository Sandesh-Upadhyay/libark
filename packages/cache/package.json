{
  "name": "@libark/cache",
  "version": "1.0.0",
  "description": "Unified cache management system for LIBARK",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./config": {
      "development": {
        "types": "./src/config/index.ts",
        "import": "./src/config/index.ts"
      },
      "types": "./dist/config/index.d.ts",
      "import": "./dist/config/index.js"
    },
    "./adapters": {
      "development": {
        "types": "./src/adapters/index.ts",
        "import": "./src/adapters/index.ts"
      },
      "types": "./dist/adapters/index.d.ts",
      "import": "./dist/adapters/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist .tsbuildinfo",
    "type-check": "tsc --noEmit",
    "test": "../../node_modules/.bin/vitest run --reporter=verbose",
    "test:watch": "../../node_modules/.bin/vitest",
    "test:coverage": "../../node_modules/.bin/vitest run --coverage"
  },
  "keywords": [
    "cache",
    "redis",
    "memory",
    "multi-tier",
    "typescript"
  ],
  "author": "LIBARK Team",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist",
    "README.md"
  ]
}
