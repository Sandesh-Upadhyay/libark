{
  "name": "@libark/media",
  "version": "1.0.0",
  "description": "統合メディア処理システム（責任分離最適化版）",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "browser": {
        "development": {
          "types": "./src/index.ts",
          "import": "./src/index.ts"
        },
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "node": {
        "development": {
          "types": "./src/index.ts",
          "import": "./src/index.ts"
        },
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "development": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./browser": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "development": {
        "types": "./src/client.ts",
        "import": "./src/client.ts"
      },
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "development": {
        "types": "./src/server.ts",
        "import": "./src/server.ts"
      },
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist .tsbuildinfo",
    "type-check": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.0.0",
    "@aws-sdk/s3-request-presigner": "^3.0.0",
    "@libark/core-shared": "workspace:*",
    "merge-stream": "^2.0.0",
    "node-fetch": "^3.3.0",
    "sharp": "^0.32.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/node-fetch": "^2.6.0",
    "@types/uuid": "^9.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "typescript": "^5.9.0",
    "vitest": "^3.2.4"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "media",
    "zenko",
    "s3",
    "presigned-url",
    "multipart-upload",
    "encryption",
    "libark"
  ],
  "author": "LIBARK Team",
  "license": "MIT"
}
