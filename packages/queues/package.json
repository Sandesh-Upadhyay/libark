{
  "name": "@libark/queues",
  "version": "1.0.0",
  "description": "Shared queue management for LibArk applications",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist .tsbuildinfo",
    "type-check": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "bullmq": "^5.0.0",
    "@libark/redis-client": "workspace:*"
  },
  "devDependencies": {},
  "files": [
    "dist"
  ]
}
