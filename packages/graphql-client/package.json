{
  "name": "@libark/graphql-client",
  "version": "1.0.0",
  "description": "LIBARK GraphQL Client",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./hooks": {
      "development": {
        "types": "./src/hooks/index.ts",
        "import": "./src/hooks/index.ts"
      },
      "import": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./client": {
      "development": {
        "types": "./src/client.ts",
        "import": "./src/client.ts"
      },
      "import": "./dist/client.js",
      "types": "./dist/client.d.ts"
    },
    "./generated/graphql": {
      "development": {
        "types": "./src/generated/graphql.ts",
        "import": "./src/generated/graphql.ts"
      },
      "import": "./dist/generated/graphql.js",
      "types": "./dist/generated/graphql.d.ts"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist .tsbuildinfo",
    "type-check": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "codegen": "graphql-codegen --config codegen.yml"
  },
  "keywords": [
    "graphql",
    "client",
    "apollo"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.11.0",
  "dependencies": {
    "@apollo/client": "^3.13.8",
    "@libark/core-client": "workspace:*",
    "@libark/core-shared": "workspace:*",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "apollo-upload-client": "^18.0.1",
    "apollo3-cache-persist": "^0.15.0",
    "graphql": "^16.9.0",
    "graphql-ws": "^6.0.5",
    "i18next": "^24.2.3",
    "zustand": "^5.0.2"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "^5.0.3",
    "@graphql-codegen/typescript": "^4.1.0",
    "@graphql-codegen/typescript-operations": "^4.3.0",
    "@graphql-codegen/typescript-react-apollo": "^4.3.2",
    "@testing-library/react": "^16.3.0",
    "@types/apollo-upload-client": "^18.0.0",
    "change-case-all": "^2.1.0",
    "magic-string": "^0.30.17",
    "vitest": "^3.2.4"
  }
}
