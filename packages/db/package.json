{
  "name": "@libark/db",
  "version": "1.0.0",
  "description": "Prisma client for LIBARK with server/client separation",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "development": {
        "types": "./src/index.ts",
        "import": "./src/index.ts"
      },
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./server": {
      "development": {
        "types": "./src/server.ts",
        "import": "./src/server.ts"
      },
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./client": {
      "development": {
        "types": "./src/client.ts",
        "import": "./src/client.ts"
      },
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "scripts": {
    "build": "tsc --build",
    "dev": "tsc --build --watch",
    "clean": "rm -rf dist .tsbuildinfo",
    "type-check": "tsc --noEmit",
    "test": "vitest run --reporter=verbose",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "data:reset": "tsx prisma/reset.ts",
    "data:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@libark/core-shared": "workspace:*",
    "@prisma/adapter-pg": "^7.2.0",
    "@prisma/client": "^7.2.0",
    "bcrypt": "^5.1.1",
    "pg": "^8.16.0",
    "prisma": "^7.2.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/pg": "^8.15.4",
    "@vitest/coverage-v8": "^3.2.4",
    "cross-env": "^7.0.3",
    "ts-node": "^10.9.1",
    "tsx": "^4.19.2",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  }
}
