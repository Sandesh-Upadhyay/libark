// P2P取引リクエスト
model P2PTradeRequest {
  id              String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  buyerId         String          @map("buyer_id") @db.Uuid
  sellerId        String?         @map("seller_id") @db.Uuid
  amountUsd       Decimal         @map("amount_usd") @db.Decimal(20, 8)
  fiatCurrency    String          @map("fiat_currency") @db.VarChar(10)
  fiatAmount      Decimal         @map("fiat_amount") @db.Decimal(20, 8)
  exchangeRate    Decimal         @map("exchange_rate") @db.Decimal(20, 8)
  status          P2PTradeStatus  @default(PENDING)
  paymentMethod   P2PPaymentMethodType? @map("payment_method") // Enumに変更
  paymentDetails  String?         @map("payment_details")  // 暗号化
  escrowAmount    Decimal?        @map("escrow_amount") @db.Decimal(20, 8)
  expiresAt       DateTime        @map("expires_at") @db.Timestamptz(6)
  completedAt     DateTime?       @map("completed_at") @db.Timestamptz(6)
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  offerId         String?         @map("offer_id") @db.Uuid
  p2pOffer        P2POffer?       @relation(fields: [offerId], references: [id])

  buyer           User            @relation("P2PBuyer", fields: [buyerId], references: [id])
  seller          User?           @relation("P2PSeller", fields: [sellerId], references: [id])
  dispute         P2PDispute?

  @@index([buyerId, status])
  @@index([sellerId, status])
  @@index([status, expiresAt])
  @@index([offerId])
  @@map("p2p_trade_requests")
}

// P2Pオファー（支払い方法単位）
model P2POffer {
  id                 String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sellerId           String  @map("seller_id") @db.Uuid

  paymentMethod      P2PPaymentMethodType @map("payment_method")
  minAmountUsd       Decimal @map("min_amount_usd") @db.Decimal(20, 8)
  maxAmountUsd       Decimal @map("max_amount_usd") @db.Decimal(20, 8)
  fiatCurrency       String  @map("fiat_currency") @db.VarChar(10)
  exchangeRateMargin Decimal @map("exchange_rate_margin") @db.Decimal(20, 8)
  isActive           Boolean @default(true)

  // 将来拡張枠（最小）
  instructions       String?  @map("instructions") @db.Text
  priority           Int      @default(0) @map("priority")

  createdAt          DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  seller             User     @relation("P2POffer", fields: [sellerId], references: [id])
  tradeRequests      P2PTradeRequest[]

  @@index([sellerId])
  @@index([paymentMethod, fiatCurrency, isActive])
  @@index([fiatCurrency, isActive, priority])
  @@unique([sellerId, paymentMethod, fiatCurrency])
  @@map("p2p_offers")
}

