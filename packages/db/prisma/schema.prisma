// NOWPayments決済情報（ユーザー・管理者目線で最適化）
model NOWPaymentsPayment {
  // 基本識別情報
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  paymentId       String   @unique @map("payment_id") @db.VarChar(100)        // NOWPayments Payment ID
  orderId         String   @map("order_id") @db.VarChar(100)                  // 内部注文ID
  purchaseId      String?  @map("purchase_id") @db.VarChar(100)               // NOWPayments Purchase ID

  // 決済ステータス・タイプ
  paymentStatus   NOWPaymentsStatus @map("payment_status")                    // 決済ステータス
  paymentType     NOWPaymentsType   @default(CRYPTO2CRYPTO) @map("payment_type") // 決済タイプ

  // 価格情報（ユーザーが支払う予定の金額）
  priceAmount     Decimal  @map("price_amount") @db.Decimal(18, 8)            // 元の価格
  priceCurrency   String   @map("price_currency") @db.VarChar(10)             // 元の通貨（通常USD）

  // 支払い情報（実際の暗号通貨での支払い）
  payAmount       Decimal  @map("pay_amount") @db.Decimal(18, 8)              // 支払い予定額（暗号通貨）
  payCurrency     String   @map("pay_currency") @db.VarChar(10)               // 支払い通貨（XRP, BTC等）
  actuallyPaid    Decimal? @map("actually_paid") @db.Decimal(18, 8)           // 実際に支払われた額

  // アドレス情報
  payAddress      String   @map("pay_address") @db.VarChar(255)               // 支払い先アドレス
  payinExtraId    String?  @map("payin_extra_id") @db.VarChar(100)            // Extra ID (XRP等で必要)
  payoutAddress   String?  @map("payout_address") @db.VarChar(255)            // 出金先アドレス

  // 結果情報
  outcomeAmount   Decimal? @map("outcome_amount") @db.Decimal(18, 8)          // 最終的な受取額
  outcomeCurrency String?  @map("outcome_currency") @db.VarChar(10)           // 最終的な受取通貨

  // レート・手数料情報
  fixedRate       Boolean  @default(false) @map("fixed_rate")                 // 固定レートかどうか
  feePaidByUser   Boolean  @default(false) @map("fee_paid_by_user")           // ユーザーが手数料を負担するか

  // メタ情報
  orderDescription String? @map("order_description") @db.Text                 // 注文説明

  // タイムスタンプ
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  // NOWPayments側のタイムスタンプ
  nowpaymentsCreatedAt DateTime? @map("nowpayments_created_at") @db.Timestamptz(6)
  nowpaymentsUpdatedAt DateTime? @map("nowpayments_updated_at") @db.Timestamptz(6)

  // リレーション
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // インデックス（パフォーマンス最適化）
  @@index([userId])                    // ユーザー別検索
  @@index([paymentStatus])             // ステータス別検索
  @@index([createdAt])                 // 時系列検索
  @@index([paymentId])                 // Payment ID検索
  @@index([payCurrency])               // 通貨別検索
  @@index([userId, paymentStatus])     // ユーザー×ステータス複合検索
  @@index([userId, createdAt])         // ユーザー×時系列複合検索
  @@map("nowpayments_payments")
}

