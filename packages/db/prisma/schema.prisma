generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                 String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  username           String              @unique @db.VarChar(30)
  email              String              @unique @db.VarChar(255)
  passwordHash       String              @map("password_hash") @db.VarChar(255)
  displayName        String?             @map("display_name") @db.VarChar(50)
  bio                String?
  profileImageId     String?             @map("profile_image_id") @db.Uuid
  coverImageId       String?             @map("cover_image_id") @db.Uuid
  createdAt          DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime            @default(now()) @map("updated_at") @db.Timestamptz(6)
  lastLoginAt        DateTime?           @map("last_login_at") @db.Timestamptz(6)
  isVerified         Boolean             @default(false) @map("is_verified")
  isActive           Boolean             @default(true) @map("is_active")

  // 🔐 2FA (Two-Factor Authentication) 関連フィールド
  twoFactorEnabled   Boolean             @default(false) @map("two_factor_enabled")
  twoFactorSecret    String?             @map("two_factor_secret") @db.VarChar(255)
  backupCodes        String[]            @default([]) @map("backup_codes")
  twoFactorEnabledAt DateTime?           @map("two_factor_enabled_at") @db.Timestamptz(6)

  // 🎯 新しいロールベースシステム
  role               Role?               @relation(fields: [roleId], references: [id])
  roleId             String?             @map("role_id") @db.Uuid
  permissionOverrides UserPermissionOverride[]
  grantedPermissions UserPermissionOverride[] @relation("GrantedPermissions")
  comments           Comment[]
  depositRequests    DepositRequest[]
  likes              Like[]
  media              Media[]              // メディア
  messages           Message[]
  messageReads       MessageRead[]
  messageHidden      MessageHidden[]     // 個人削除したメッセージ
  conversationParticipants ConversationParticipant[]
  createdConversations Conversation[]    @relation("ConversationCreator")
  actorNotifications Notification[]      @relation("NotificationActor")
  notifications      Notification[]
  posts              Post[]
  postPurchases      PostPurchase[]      // 購入記録
  settings           UserSettings?
  userWallets        UserWallet[]
  walletTransactions WalletTransaction[]
  wallet             Wallet?
  withdrawalRequests WithdrawalRequest[]
  nowpaymentsPayments NOWPaymentsPayment[]
  paymentRequests    PaymentRequest[]

  // P2P取引リレーション
  p2pTradeRequestsAsBuyer  P2PTradeRequest[]  @relation("P2PBuyer")
  p2pTradeRequestsAsSeller P2PTradeRequest[]  @relation("P2PSeller")
  p2pOffers                P2POffer[]          @relation("P2POffer")
  p2pBuyerPreferences      P2PBuyerPreference[] @relation("P2PBuyerPreference")
  p2pDisputesInitiated     P2PDispute[]       @relation("DisputeInitiator")
  p2pDisputesResolved      P2PDispute[]       @relation("DisputeResolver")

  // サイト機能設定関係
  updatedSiteFeatures SiteFeatureSetting[] @relation("SiteFeatureUpdatedBy")
  userFeaturePermissions UserFeaturePermission[] @relation("UserFeaturePermissions")
  grantedFeaturePermissions UserFeaturePermission[] @relation("GrantedFeaturePermissions")

  // フォロー関係
  following          Follow[]            @relation("UserFollowing")
  followers          Follow[]            @relation("UserFollowers")

  // アバター・カバー画像のリレーション
  profileImage       Media?              @relation("UserProfileImage", fields: [profileImageId], references: [id])
  coverImage         Media?              @relation("UserCoverImage", fields: [coverImageId], references: [id])

  @@map("users")
}

model Post {
  id           String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String         @map("user_id") @db.Uuid
  content      String?
  isProcessing Boolean        @default(true) @map("is_processing")
  isDeleted    Boolean        @default(false) @map("is_deleted")
  createdAt    DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime       @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?      @map("deleted_at") @db.Timestamptz(6)
  visibility   PostVisibility @default(PUBLIC)

  // Paid投稿設定
  price        Decimal?       @db.Decimal(10,2) // Paid投稿の価格（必須：PAID時）
  paidAt       DateTime?      @map("paid_at") @db.Timestamptz(6) // Paid化された日時

  comments     Comment[]
  likes        Like[]
  media        Media[]        // メディア
  user         User           @relation(fields: [userId], references: [id])
  purchases    PostPurchase[] // 購入記録

  @@index([userId])
  @@index([createdAt])
  @@index([visibility, isDeleted])
  @@map("posts")
}

// 🎯 有料投稿購入システム
model PostPurchase {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid // 購入者
  postId      String    @map("post_id") @db.Uuid // 購入対象投稿
  price       Decimal   @db.Decimal(10,2) // 購入価格
  purchasedAt DateTime  @default(now()) @map("purchased_at") @db.Timestamptz(6) // 購入日時
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz(6) // 有効期限（オプション）
  isActive    Boolean   @default(true) @map("is_active") // 購入の有効性

  // リレーション
  user        User      @relation(fields: [userId], references: [id])
  post        Post      @relation(fields: [postId], references: [id])

  @@unique([userId, postId]) // 同一ユーザー・投稿の重複購入防止
  @@index([userId])
  @@index([postId])
  @@index([purchasedAt])
  @@index([expiresAt])
  @@map("post_purchases")
}

// 🎯 統一メディアシステム（責任分離最適化版）
model Media {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String      @map("user_id") @db.Uuid
  postId      String?     @map("post_id") @db.Uuid

  // 基本情報（シンプル化）
  filename    String      @db.VarChar(255)
  s3Key       String      @map("s3_key") @db.VarChar(500)  // s3Key → s3Key
  mimeType    String      @map("mime_type") @db.VarChar(100)
  fileSize    Int         @map("file_size")
  width       Int?
  height      Int?

  // メディアタイプ
  type        MediaType   @default(POST)

  // 処理ステータス（シンプル化）
  status      MediaStatus @default(PROCESSING)

  // タイムスタンプ
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)

  // リレーション
  user        User        @relation(fields: [userId], references: [id])
  post        Post?       @relation(fields: [postId], references: [id])
  variants    MediaVariant[]
  ogpPublicMedia OgpPublicMedia[]

  // アバター・カバー画像の逆方向リレーション
  userProfileImage User[] @relation("UserProfileImage")
  userCoverImage   User[] @relation("UserCoverImage")

  @@index([userId])
  @@index([postId])
  @@index([status])
  @@index([type])
  @@index([s3Key])
  @@index([createdAt])
  @@map("media")
}



// 🎨 メディアバリアント管理（責任分離最適化版）
model MediaVariant {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mediaId   String      @map("media_id") @db.Uuid
  type      VariantType // 統一バリアントタイプ
  s3Key     String      @map("s3_key") @db.VarChar(500)  // s3Key → s3Key
  width     Int
  height    Int
  fileSize  Int         @map("file_size")
  quality   Int         // WebP品質設定
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  media     Media       @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, type])
  @@index([mediaId])
  @@index([type])
  @@index([s3Key])
  @@map("media_variants")
}



// 🎯 OGP匿名配信用メディアテーブル
model OgpPublicMedia {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mediaId     String   @map("media_id") @db.Uuid
  bucket      String   @db.VarChar(100)
  backendId   String   @map("backend_id") @db.VarChar(100)
  ogpKey      String   @map("ogp_key") @db.VarChar(500)
  contentHash String   @map("content_hash") @db.VarChar(64)
  contentType String   @map("content_type") @db.VarChar(100)
  ext         String   @db.VarChar(10)
  variant     String   @db.VarChar(50)
  salt        String   @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  media       Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)

  @@unique([mediaId, variant])
  @@index([mediaId])
  @@index([ogpKey])
  @@index([contentHash])
  @@index([backendId])
  @@index([createdAt])
  @@map("ogp_public_media")
}


// 📝 移行ログテーブル
model MigrationLog {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  operation        String    @db.VarChar(100)
  tableName        String    @map("table_name") @db.VarChar(100)
  recordsProcessed Int       @default(0) @map("records_processed")
  recordsSuccess   Int       @default(0) @map("records_success")
  recordsFailed    Int       @default(0) @map("records_failed")
  errorDetails     String?   @map("error_details")
  startedAt        DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  completedAt      DateTime? @map("completed_at") @db.Timestamptz(6)
  status           String    @default("RUNNING") @db.VarChar(20)

  @@map("migration_log")
}

// メッセージ機能の列挙型
enum ConversationType {
  DIRECT // 1対1の会話
  GROUP  // グループチャット（将来実装）

  @@map("conversation_type")
}

enum MessageType {
  TEXT   // テキストメッセージ
  IMAGE  // 画像メッセージ（将来実装）
  FILE   // ファイルメッセージ（将来実装）
  SYSTEM // システムメッセージ（将来実装）

  @@map("message_type")
}

enum ParticipantRole {
  MEMBER // 一般メンバー
  ADMIN  // 管理者（将来実装）

  @@map("participant_role")
}

// 会話テーブル
model Conversation {
  id          String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  type        ConversationType          @default(DIRECT)
  title       String?                   @db.VarChar(100) // グループチャット用タイトル
  createdBy   String                    @map("created_by") @db.Uuid
  isArchived  Boolean                   @default(false) @map("is_archived")
  createdAt   DateTime                  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime                  @default(now()) @map("updated_at") @db.Timestamptz(6)

  // リレーション
  creator      User                     @relation("ConversationCreator", fields: [createdBy], references: [id])
  messages     Message[]
  participants ConversationParticipant[]

  @@index([type])
  @@index([createdBy])
  @@index([updatedAt])
  @@index([isArchived])
  @@map("conversations")
}

// 会話参加者テーブル
model ConversationParticipant {
  id             String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String           @map("conversation_id") @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  role           ParticipantRole  @default(MEMBER)
  joinedAt       DateTime         @default(now()) @map("joined_at") @db.Timestamptz(6)
  leftAt         DateTime?        @map("left_at") @db.Timestamptz(6) // 退出時刻
  isMuted        Boolean          @default(false) @map("is_muted")
  lastReadAt     DateTime?        @map("last_read_at") @db.Timestamptz(6) // 最後に読んだ時刻

  // リレーション
  conversation   Conversation     @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([conversationId, userId])
  @@index([userId, leftAt]) // ユーザーの参加中会話を高速取得
  @@index([conversationId, leftAt]) // アクティブ参加者取得用
  @@index([lastReadAt]) // 既読管理用
  @@map("conversation_participants")
}

// メッセージテーブル
model Message {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  conversationId String      @map("conversation_id") @db.Uuid
  senderId       String      @map("sender_id") @db.Uuid
  content        String      @db.Text
  type           MessageType @default(TEXT)
  replyToId      String?     @map("reply_to_id") @db.Uuid // 返信機能用
  editedAt       DateTime?   @map("edited_at") @db.Timestamptz(6) // 編集機能用
  deletedAt      DateTime?   @map("deleted_at") @db.Timestamptz(6) // ソフトデリート
  createdAt      DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime    @default(now()) @map("updated_at") @db.Timestamptz(6)

  // リレーション
  conversation   Conversation    @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User            @relation(fields: [senderId], references: [id])
  replyTo        Message?        @relation("MessageReply", fields: [replyToId], references: [id])
  replies        Message[]       @relation("MessageReply")
  reads          MessageRead[]
  hiddenBy       MessageHidden[] // 個人削除（トーク削除）

  @@index([conversationId, createdAt]) // 会話のメッセージ一覧用
  @@index([senderId, createdAt]) // 送信者のメッセージ履歴用
  @@index([replyToId]) // 返信機能用
  @@index([deletedAt]) // ソフトデリート対応
  @@index([type])
  @@map("messages")
}

// メッセージ既読状況テーブル
model MessageRead {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  readAt    DateTime @default(now()) @map("read_at") @db.Timestamptz(6)

  // リレーション
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId]) // 同じメッセージを同じユーザーが複数回既読にできない
  @@index([userId, readAt]) // ユーザーの既読履歴用
  @@index([messageId]) // メッセージの既読状況用
  @@map("message_reads")
}

// メッセージ個人削除テーブル（トーク削除用）
model MessageHidden {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId String   @map("message_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  hiddenAt  DateTime @default(now()) @map("hidden_at") @db.Timestamptz(6)

  // リレーション
  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id])

  @@unique([messageId, userId]) // 同じメッセージを同じユーザーが複数回非表示にしない
  @@index([userId, hiddenAt]) // ユーザーの非表示履歴用
  @@index([messageId]) // メッセージの非表示状況確認用
  @@map("message_hidden")
}

model Like {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  postId    String?  @map("post_id") @db.Uuid
  commentId String?  @map("comment_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  post      Post?    @relation(fields: [postId], references: [id], onDelete: Cascade)
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
  @@unique([userId, commentId])
  @@index([postId])
  @@index([commentId])
  @@index([userId])
  @@map("likes")
}

model Follow {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  followerId  String   @map("follower_id") @db.Uuid  // フォローする人
  followingId String   @map("following_id") @db.Uuid // フォローされる人
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // リレーション
  follower    User     @relation("UserFollowing", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("UserFollowers", fields: [followingId], references: [id], onDelete: Cascade)

  // 同じユーザーを複数回フォローできないようにする
  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@index([createdAt])
  @@map("follows")
}

model Comment {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  postId       String    @map("post_id") @db.Uuid
  content      String
  isDeleted    Boolean   @default(false) @map("is_deleted")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime  @default(now()) @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6)
  isProcessing Boolean   @default(true) @map("is_processing")
  post         Post      @relation(fields: [postId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  likes        Like[]

  @@index([postId])
  @@index([userId])
  @@index([createdAt])
  @@index([isProcessing])
  @@map("comments")
}

model Notification {
  id          String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  type        NotificationType
  actorId     String?          @map("actor_id") @db.Uuid
  referenceId String?          @map("reference_id") @db.Uuid
  content     String?
  isRead      Boolean          @default(false) @map("is_read")
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz(6)
  readAt      DateTime?        @map("read_at") @db.Timestamptz(6)
  actor       User?            @relation("NotificationActor", fields: [actorId], references: [id])
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([actorId])
  @@index([type])
  @@index([createdAt])
  @@index([isRead])
  @@map("notifications")
}

model UserSettings {
  userId            String   @id @map("user_id") @db.Uuid
  theme             String   @default("system") @db.VarChar(10)
  animationsEnabled Boolean  @default(true) @map("animations_enabled")
  locale            String   @default("ja") @db.VarChar(10)
  contentFilter     String   @default("all") @map("content_filter") @db.VarChar(20)
  displayMode       String   @default("card") @map("display_mode") @db.VarChar(10)
  timezone          String   @default("Asia/Tokyo") @db.VarChar(50)
  updatedAt         DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Wallet {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @unique @map("user_id") @db.Uuid
  balanceUsd      Decimal  @default(0) @map("balance_usd") @db.Decimal(20, 8)
  salesBalanceUsd Decimal  @default(0) @map("sales_balance_usd") @db.Decimal(20, 8)
  p2pBalanceUsd   Decimal  @default(0) @map("p2p_balance_usd") @db.Decimal(20, 8)
  p2pLockedUsd    Decimal  @default(0) @map("p2p_locked_usd") @db.Decimal(20, 8)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wallets")
}

model UserWallet {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  walletName String   @map("wallet_name") @db.VarChar(100)
  currency   String   @db.VarChar(10)
  network    String   @db.VarChar(50)
  address    String   @db.VarChar(255)
  isVerified Boolean  @default(false) @map("is_verified")
  isActive   Boolean  @default(true) @map("is_active")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, address, currency, network])
  @@index([address, currency, network])
  @@map("user_wallets")
}

// 🎯 新しい汎用決済システム

// 決済プロバイダー管理
model PaymentProvider {
  id          String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String      @unique @db.VarChar(50) // "nowpayments", "mexc", "coinpayments", "bybit"
  displayName String      @db.VarChar(100) // "NOWPayments", "MEXC", "CoinPayments", "Bybit"
  type        ProviderType // CRYPTO_DEPOSIT, CRYPTO_WITHDRAWAL, P2P
  isActive    Boolean     @default(true)
  config      Json?       // プロバイダー固有の設定
  createdAt   DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  paymentRequests PaymentRequest[]

  @@index([type, isActive])
  @@map("payment_providers")
}

// 統一リクエスト管理
model PaymentRequest {
  id            String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  providerId    String        @map("provider_id") @db.Uuid
  type          RequestType   // DEPOSIT, WITHDRAWAL
  method        PaymentMethod // CRYPTO, P2P
  amountUsd     Decimal       @map("amount_usd") @db.Decimal(20, 8)
  currency      String?       @db.VarChar(10)
  currencyAmount Decimal?     @map("currency_amount") @db.Decimal(20, 8)
  status        RequestStatus @default(PENDING)
  metadata      Json?
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  provider      PaymentProvider @relation(fields: [providerId], references: [id])
  user          User @relation(fields: [userId], references: [id], onDelete: Cascade)
  externalTransactions ExternalTransaction[]
  walletTransactions   WalletTransaction[]

  @@index([userId, createdAt])
  @@index([status, type])
  @@index([providerId, status])
