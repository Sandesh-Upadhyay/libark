# LIBARK Environment Template
# Usage:
# 1) copy to .env.development for local/docker development
# 2) copy to .env.production for production deployment

# ================================
# Runtime
# ================================
NODE_ENV=development
PORT=8000
DOCKER_CONTAINER=true
NODE_OPTIONS=--max-old-space-size=4096
WATCHPACK_POLLING=true
CHOKIDAR_USEPOLLING=true
NEXT_TELEMETRY_DISABLED=1

# ================================
# Public URLs
# ================================
NEXT_PUBLIC_FRONTEND_URL=http://localhost
NEXT_PUBLIC_BACKEND_URL=http://localhost:8000
NEXT_PUBLIC_BACKEND_URL_INTERNAL=http://backend:8000
NEXT_PUBLIC_GRAPHQL_URL=http://localhost/graphql
NEXT_PUBLIC_WEBSOCKET_PATH=/graphql
NEXT_PUBLIC_MEDIA_URL=http://localhost/files/media
NEXT_PUBLIC_S3_GATEWAY_URL=http://localhost
PUBLIC_URL=http://localhost:8000

# ================================
# Database / Redis
# ================================
DATABASE_URL=postgresql://libark_db_admin:LibarkDB2024@postgres:5432/libark_db
POSTGRES_DB=libark_db
POSTGRES_USER=libark_db_admin
POSTGRES_PASSWORD=LibarkDB2024
REDIS_URL=redis://redis:6379
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ================================
# Auth
# ================================
JWT_SECRET=change_me_jwt_secret_for_local_development
REFRESH_TOKEN_SECRET=change_me_refresh_secret_for_local_development
JWT_EXPIRES_IN=4h
REFRESH_TOKEN_EXPIRES_IN=7d
ADMIN_INITIAL_PASSWORD=change_me_admin_initial_password

# ================================
# S3 / Media
# ================================
# This project uses S3 Gateway for all media operations.
# Base S3_* values are auto-derived from S3_BACKEND_* when omitted.
# Keep S3_BACKEND_* as the single source of truth for credentials/bucket.
S3_BUCKET=media
S3_REGION=auto
S3_ENDPOINT=http://s3-gateway:8080
S3_GATEWAY_URL=http://s3-gateway:8080
S3_GATEWAY_PORT=8080
S3_GATEWAY_TIMEOUT=30000
S3_PUBLIC_URL=http://localhost/files/media
S3_CDN_DOMAIN=http://localhost/files
S3_AVATAR_CDN_URL=http://localhost/files/media/avatars
S3_COVER_CDN_URL=http://localhost/files/media/covers
S3_PRESIGNED_EXPIRES_IN=3600
S3_GATEWAY_CACHE_MAX_AGE=86400
S3_GATEWAY_PUBLIC_PATHS=/ogp/,/avatars/
S3_GATEWAY_CORS_ORIGIN=http://localhost:3000,http://localhost:3001
S3_GATEWAY_CORS_CREDENTIALS=true

# Backend storage provider (R2/AWS/GCS/DO)
S3_BACKEND_TYPE=r2
S3_BACKEND_ACCESS_KEY=dev_r2_access_key
S3_BACKEND_SECRET_KEY=dev_r2_secret_key
S3_BACKEND_BUCKET=media
S3_BACKEND_ENDPOINT=https://example.r2.cloudflarestorage.com
S3_BACKEND_REGION=auto

# SSE-C
S3_GATEWAY_ENCRYPTION_ENABLED=true
S3_GATEWAY_ENCRYPTION_ALGORITHM=AES256
S3_GATEWAY_ENCRYPTION_KEY=replace_with_32byte_base64_key

# ================================
# OGP
# ================================
OGP_INTERNAL_API_TOKEN=replace_with_internal_api_token
OGP_INTERNAL_API_BASE_URL=http://backend:8000
OGP_SIGNING_KEY=replace_with_32_or_more_chars_signing_key
OGP_SIGNATURE_EXPIRES_IN=1209600
OGP_MAX_FUTURE_SEC=2592000
OGP_REDIS_TTL_SEC=86400

# ================================
# WebSocket
# ================================
WEBSOCKET_PATH=/graphql
WEBSOCKET_ENABLED=true
WEBSOCKET_CORS_ORIGINS=http://localhost:3000,http://localhost:3001
WEBSOCKET_MAX_CONNECTIONS=1000
WEBSOCKET_DEBUG=true
WEBSOCKET_CONNECTION_TIMEOUT=30000
WEBSOCKET_AUTHENTICATION_TIMEOUT=15000

# ================================
# Cache
# ================================
CACHE_ENABLED=true
CACHE_MEMORY_ENABLED=true
CACHE_MEMORY_MAX_SIZE=104857600
CACHE_MEMORY_DEFAULT_TTL=300
CACHE_REDIS_ENABLED=true
CACHE_REDIS_DEFAULT_TTL=3600
CACHE_REDIS_KEY_PREFIX=libark:cache
CACHE_COMPRESSION_ENABLED=true
CACHE_COMPRESSION_THRESHOLD=1024
CACHE_COMPRESSION_LEVEL=6
CACHE_TTL_USER=3600
CACHE_TTL_POST=1800
CACHE_TTL_FEED=900
CACHE_TTL_MEDIA=86400
CACHE_TTL_SEARCH=300
CACHE_TTL_SESSION=7200
CACHE_TTL_GRAPHQL=300
CACHE_TTL_API=600
CACHE_TTL_CONFIG=3600
CACHE_TTL_TEMP=60
CACHE_METRICS_ENABLED=true
CACHE_METRICS_UPDATE_INTERVAL=60
CACHE_METRICS_DETAILED=false
CACHE_LOG_LEVEL=info
CACHE_LOG_OPERATIONS=false
CACHE_LOG_PERFORMANCE=false
CACHE_DEVELOPMENT_ENABLED=false
CACHE_DEVELOPMENT_DEBUG=false
CACHE_DEVELOPMENT_TEST_MODE=false

# ================================
# Worker / Queue
# ================================
BULL_BOARD_ENABLED=true
BULL_BOARD_BASE_PATH=/admin/queues

# ================================
# Security / Feature toggles
# ================================
DEBUG_IMAGES=true
LOG_LEVEL=info
LOG_CATEGORIES=INIT,MEDIA,SYSTEM
LOG_THROTTLE_MS=100

# ================================
# NOWPayments
# ================================
NOWPAYMENTS_USE_MOCK=true
NOWPAYMENTS_IS_SANDBOX=false
NOWPAYMENTS_API_KEY=replace_with_nowpayments_api_key
NOWPAYMENTS_IPN_SECRET=replace_with_nowpayments_ipn_secret
NOWPAYMENTS_BASE_URL=https://api.nowpayments.io/v1
