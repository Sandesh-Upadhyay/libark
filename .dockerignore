# =============================================================================
# LIBARK Docker Build Context Ignore
# =============================================================================
# ビルドコンテキストのサイズを削減し、ビルド時間を短縮

# -----------------------------------------------------------------------------
# Dependencies & Build Outputs
# -----------------------------------------------------------------------------
node_modules
**/node_modules
**/dist
**/.next
**/.turbo
**/coverage
**/build
.pnpm-store

# 古いパッケージディレクトリ
packages/core

# TypeScript cache
*.tsbuildinfo
**/*.tsbuildinfo

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# -----------------------------------------------------------------------------
# IDE & Editor
# -----------------------------------------------------------------------------
.idea
.vscode
*.swp
*.swo

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Version Control
# -----------------------------------------------------------------------------
.git
.gitignore
.github

# -----------------------------------------------------------------------------
# Cache & Temp
# -----------------------------------------------------------------------------
**/.cache
**/tmp
**/temp
**/*.tmp
**/*.temp

# -----------------------------------------------------------------------------
# Test & Coverage
# -----------------------------------------------------------------------------
**/test-results
**/playwright-report
**/.nyc_output
tests/
__tests__/
**/__mocks__/

# -----------------------------------------------------------------------------
# Large Files & Archives
# -----------------------------------------------------------------------------
*.gz
*.tar
*.zip
dependency-graph.svg
istockphoto-*.jpg

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
docs/
*.md
!README.md

# -----------------------------------------------------------------------------
# DevContainer (開発用のみ)
# -----------------------------------------------------------------------------
.devcontainer/
